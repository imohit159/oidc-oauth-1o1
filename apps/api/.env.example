DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgresdb
PORT=3000
NODE_ENV=development

JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=30d

COOKIE_SECRET=your-super-secret-cookie-key-min-32-chars
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

CORS_ORIGIN=http://localhost:3001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/identity/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/identity/github/callback

RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Admin User Seeding (optional)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=SuperSecretPassword123!
SEED_ADMIN_GIVEN_NAME=Admin
SEED_ADMIN_FAMILY_NAME=User
