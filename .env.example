# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oidc_oauth

# Server
PORT=3000
NODE_ENV=development

# JWT Keys (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# Cookies
COOKIE_SECRET=change-this-to-a-random-string-at-least-32-chars
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

# CORS
CORS_ORIGIN=http://localhost:3001

# Email (optional for development)
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Admin User Seeding (optional)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=SuperSecretPassword123!
SEED_ADMIN_GIVEN_NAME=Admin
SEED_ADMIN_FAMILY_NAME=User
